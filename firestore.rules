rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to verify user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to verify owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Scenarios rule
    match /scenarios/{scenarioId} {
      allow read, write: if isAuthenticated() && request.auth.uid == resource.data.userId || (request.resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Chat sessions and messages rule
    match /chats/{chatId} {
      allow read, write: if isAuthenticated() && request.auth.uid == resource.data.userId || (request.resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;

      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }
  }
}
